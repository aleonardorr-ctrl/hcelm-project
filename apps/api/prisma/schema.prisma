// Archivo: schema.prisma
// Ruta: apps/api/prisma/schema.prisma
// Función: Esquema principal de datos de HCELM.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  ruc                String              @unique
  active             Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  anamnesis          Anamnesis[]
  certificates       Certificate[]
  encounters         Encounter[]
  establishments     Establishment?
  hceConfigs         HceConfig?
  institutions       Institution?
  medications        Medication[]
  patients           Patient[]
  prescriptions      Prescription[]
  users              User[]
  diagnosisCatalogs  DiagnosisCatalog[]
  catalogImports     CatalogImport[]
  clinicalAlertRules ClinicalAlertRule[]
}

model User {
  id                        String              @id @default(uuid()) @db.Uuid
  tenantId                  String              @db.Uuid
  email                     String
  password                  String
  fullName                  String?
  role                      String              @default("medico")
  cmp                       String?
  rne                       String?
  active                    Boolean             @default(true)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  certificates              Certificate[]
  prescriptions             Prescription[]
  tenant                    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  diagnosisCatalogsCreated  DiagnosisCatalog[]  @relation("DiagnosisCatalogCreatedBy")
  catalogImports            CatalogImport[]     @relation("CatalogImportCreatedBy")
  clinicalAlertRulesUpdated ClinicalAlertRule[] @relation("ClinicalAlertRuleUpdatedBy")
}

model Patient {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  fullName       String
  documentNumber String
  hceNumber      String?   @db.VarChar(30)
  documentType   String    @default("DNI")
  birthDate      DateTime?
  gender         String?
  phone          String?
  email          String?
  address        String?

  allergies       String?
  chronicDiseases String?
  usualMedication String?
  observations    String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  anamnesis     Anamnesis[]
  certificates  Certificate[]
  encounters    Encounter[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  @@unique([tenantId, hceNumber])
  @@index([tenantId])
  @@index([documentNumber])
  @@index([fullName])
}

model Encounter {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  patientId String @db.Uuid

  type   String? @default("consulta")
  reason String?
  status String  @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  anamnesis  Anamnesis[]
  vitalSigns VitalSigns?
}

model VitalSigns {
  id          String @id @default(uuid()) @db.Uuid
  encounterId String @unique @db.Uuid

  systolicBP      Int?
  diastolicBP     Int?
  heartRate       Int?
  respiratoryRate Int?
  temperature     Float?
  oxygenSat       Int?

  weightKg Float?
  heightCm Float?
  bmi      Float?

  capillaryGlucose Int?
  painScale        Int?

  consciousness String?
  glasgowEye    Int?
  glasgowVerbal Int?
  glasgowMotor  Int?
  glasgowTotal  Int?

  oxygenSupport String?
  fio2          Int?
  nursingNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model Establishment {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @unique @db.Uuid
  name         String
  address      String?
  phone        String?
  email        String?
  logoUrl      String?
  directorName String?
  directorCmp  String?
  directorRne  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  patientId       String   @db.Uuid
  issuedBy        String   @db.Uuid
  certificateType String   @default("REST_CERTIFICATE")
  diagnoses       String[]
  restDays        Int?
  observations    String?
  place           String?
  issueDate       DateTime
  pdfUrl          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  issuedByUser    User     @relation(fields: [issuedBy], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Anamnesis {
  id                      String         @id @default(uuid()) @db.Uuid
  tenantId                String         @db.Uuid
  patientId               String         @db.Uuid
  encounterId             String?        @db.Uuid
  fechaAtencion           DateTime
  motivoConsulta          String
  tiempoEnfermedad        String?
  anamnesisActual         String?
  funcionesBiologicas     String?
  antecedentesPersonales  String?
  antecedentesFamiliares  String?
  signosVitales           Json?
  examenFisico            String?
  diagnosticoPrincipal    Json?
  diagnosticosSecundarios Json?
  examenesAuxiliares      String?
  prescripcionesFarmacia  String?
  destinoFinal            String         @default("alta_medica")
  issuedBy                String?        @default("admin@amehealth.pe")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  encounter               Encounter?     @relation(fields: [encounterId], references: [id])
  patient                 Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant                  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions           Prescription[]
}

model Institution {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @unique @db.Uuid
  name            String?
  legalName       String?
  ruc             String?
  address         String?
  phone           String?
  email           String?
  city            String?  @default("Arequipa")
  country         String?  @default("Perú")
  logoUrl         String?
  primaryColor    String?  @default("#0f766e")
  secondaryColor  String?  @default("#14b8a6")
  directorName    String?
  directorCmp     String?
  directorRne     String?
  timezone        String?  @default("America/Lima")
  language        String?  @default("es")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sealUrl         String?
  signatureUrl    String?
  logoHeight      Int?     @default(70)
  logoWidth       Int?     @default(70)
  sealHeight      Int?     @default(70)
  sealWidth       Int?     @default(120)
  signatureHeight Int?     @default(70)
  signatureWidth  Int?     @default(180)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HceConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @unique @db.Uuid
  requireCie10           Boolean  @default(true)
  allowMultipleDiagnoses Boolean  @default(true)
  defaultRestDays        Int      @default(1)
  requireVitalSigns      Boolean  @default(true)
  autoSaveDrafts         Boolean  @default(true)
  signatureRequired      Boolean  @default(true)
  customFields           Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Medication {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @db.Uuid
  genericName       String
  commercialName    String?
  concentration     String?
  presentation      String
  route             String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptionItems PrescriptionItem[]
}

model Prescription {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @db.Uuid
  patientId   String             @db.Uuid
  anamnesisId String?            @db.Uuid
  issuedBy    String             @db.Uuid
  issueDate   DateTime           @default(now())
  notes       String?
  pdfUrl      String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  anamnesis   Anamnesis?         @relation(fields: [anamnesisId], references: [id])
  doctor      User               @relation(fields: [issuedBy], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(uuid()) @db.Uuid
  prescriptionId String       @db.Uuid
  medicationId   String       @db.Uuid
  quantity       Int
  route          String?
  dose           String?
  frequency      String?
  durationDays   Int?
  indications    String?
  createdAt      DateTime     @default(now())
  medication     Medication   @relation(fields: [medicationId], references: [id])
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
}

model DiagnosisCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  system       String   @default("CIE10") @db.VarChar(10)
  code         String   @db.VarChar(20)
  description  String   @db.Text
  chapter      String?  @db.VarChar(255)
  group        String?  @db.VarChar(255)
  subgroup     String?  @db.VarChar(255)
  synonyms     String[] @default([])
  searchText   String   @default("") @db.Text
  active       Boolean  @default(true)
  observations String?  @db.Text
  source       String?  @db.VarChar(255)
  createdById  String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("DiagnosisCatalogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tenantId, system, code])
  @@index([tenantId, system, active])
  @@index([tenantId, code])
}

model CatalogImport {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  catalogType      String    @db.VarChar(30)
  sourceFileName   String    @db.VarChar(255)
  source           String?   @db.VarChar(255)
  status           String    @default("PENDING") @db.VarChar(20)
  totalRows        Int       @default(0)
  validRows        Int       @default(0)
  invalidRows      Int       @default(0)
  createdRows      Int       @default(0)
  updatedRows      Int       @default(0)
  skippedRows      Int       @default(0)
  errorRows        Int       @default(0)
  validationReport Json?
  createdById      String?   @db.Uuid
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("CatalogImportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, catalogType, createdAt])
  @@index([tenantId, status])
}

model ClinicalAlertRule {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  key           String   @db.VarChar(80)
  name          String   @db.VarChar(160)
  abbreviation  String   @db.VarChar(20)
  category      String   @default("vital_signs") @db.VarChar(40)
  sourceType    String   @default("VITAL_SIGNS") @db.VarChar(40)
  displayFields String[] @default([])
  unit          String?  @db.VarChar(30)
  referenceKey  String?  @db.VarChar(80)
  sourceNote    String?  @db.Text
  active        Boolean  @default(true)
  displayOrder  Int      @default(0)
  version       Int      @default(1)
  updatedById   String?  @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?               @relation("ClinicalAlertRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  bands         ClinicalAlertBand[]

  @@unique([tenantId, key])
  @@index([tenantId, active, displayOrder])
  @@index([tenantId, sourceType])
}

model ClinicalAlertBand {
  id              String   @id @default(uuid()) @db.Uuid
  ruleId          String   @db.Uuid
  key             String   @db.VarChar(80)
  severity        String   @db.VarChar(20)
  label           String   @db.VarChar(100)
  symbol          String?  @db.VarChar(10)
  colorHex        String?  @db.VarChar(9)
  matchMode       String   @default("ALL") @db.VarChar(10)
  messageTemplate String   @db.Text
  suggestedAction String?  @db.Text
  active          Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rule       ClinicalAlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  conditions ClinicalAlertCondition[]

  @@unique([ruleId, key])
  @@index([ruleId, active, priority])
}

model ClinicalAlertCondition {
  id          String   @id @default(uuid()) @db.Uuid
  bandId      String   @db.Uuid
  sourceField String   @db.VarChar(80)
  operator    String   @db.VarChar(20)
  value1      Float
  value2      Float?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  band ClinicalAlertBand @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@index([bandId, order])
}
