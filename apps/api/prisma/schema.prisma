  displayOrder    Int      @default(0)
  updatedById     String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, companyId, businessUnitId, ruleKey])
  @@index([tenantId, companyId, businessUnitId, active, displayOrder])
  @@index([updatedById])
}

