// Archivo: schema.prisma
// Ruta: apps/api/prisma/schema.prisma
// Función: Esquema principal de datos de HCELM.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdministrativeEntityStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum PlatformAdministrativeEntityType {
  TENANT
  COMPANY
  USER
}

enum PlatformAdministrativeAction {
  SUSPEND
  REACTIVATE
}

enum PlatformAdministrativeExecutionSource {
  USER
  SYSTEM
}

model Tenant {
  id                          String                        @id @default(uuid()) @db.Uuid
  name                        String
  ruc                         String                        @unique
  active                      Boolean                       @default(true)
  status                      AdministrativeEntityStatus    @default(ACTIVE)
  suspendedAt                 DateTime?
  suspendedUntil              DateTime?
  suspensionCategory          String?                       @db.VarChar(50)
  suspensionReason            String?                       @db.VarChar(500)
  suspendedByPlatformUserId   String?                       @db.Uuid
  reactivatedAt               DateTime?
  reactivatedByPlatformUserId String?                       @db.Uuid
  reactivationReason          String?                       @db.VarChar(500)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  anamnesis                   Anamnesis[]
  certificates                Certificate[]
  encounters                  Encounter[]
  establishments              Establishment?
  hceConfigs                  HceConfig?
  institutions                Institution?
  medications                 Medication[]
  medicationLots              MedicationInventoryLot[]
  patients                    Patient[]
  prescriptions               Prescription[]
  users                       User[]
  diagnosisCatalogs           DiagnosisCatalog[]
  catalogImports              CatalogImport[]
  clinicalAlertRules          ClinicalAlertRule[]
  laboratoryCatalogs          LaboratoryCatalog[]
  systemModules               TenantSystemModule[]
  companies                   Company[]
  businessUnits               BusinessUnit[]
  warehouses                  Warehouse[]
  companyMedications          CompanyMedication[]
  userCompanyMemberships      UserCompanyMembership[]
  inventoryMovements          MedicationInventoryMovement[]

  pharmacySales             PharmacySale[]
  pharmacySaleItems         PharmacySaleItem[]
  pharmacySaleAllocations   PharmacySaleItemAllocation[]
  pharmacySalePayments      PharmacySalePayment[]
  pharmacyDocumentSequences PharmacyDocumentSequence[]

  companyFiscalProfiles          CompanyFiscalProfile[]
  commercialCustomers            CommercialCustomer[]
  electronicDocumentSequences    ElectronicDocumentSequence[]
  electronicDocuments            ElectronicDocument[]
  electronicDocumentLines        ElectronicDocumentLine[]
  electronicDocumentDeliveries   ElectronicDocumentDelivery[]
  electronicDocumentEvents       ElectronicDocumentEvent[]
  electronicDocumentJobs         ElectronicDocumentJob[]
  moduleInstallations            CompanyModuleInstallation[]
  companyCollaborationAgreements CompanyCollaborationAgreement[]
  prescriptionReferrals          PrescriptionReferral[]
}

model User {
  id                          String                        @id @default(uuid()) @db.Uuid
  tenantId                    String                        @db.Uuid
  email                       String
  password                    String
  dni                         String?                       @db.VarChar(8)
  fullName                    String?
  role                        String                        @default("medico")
  platformRole                String?                       @db.VarChar(40)
  cmp                         String?
  rne                         String?
  active                      Boolean                       @default(true)
  status                      AdministrativeEntityStatus    @default(ACTIVE)
  suspendedAt                 DateTime?
  suspendedUntil              DateTime?
  suspensionCategory          String?                       @db.VarChar(50)
  suspensionReason            String?                       @db.VarChar(500)
  suspendedByPlatformUserId   String?                       @db.Uuid
  reactivatedAt               DateTime?
  reactivatedByPlatformUserId String?                       @db.Uuid
  reactivationReason          String?                       @db.VarChar(500)
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  certificates                Certificate[]
  prescriptions               Prescription[]
  tenant                      Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  diagnosisCatalogsCreated    DiagnosisCatalog[]            @relation("DiagnosisCatalogCreatedBy")
  catalogImports              CatalogImport[]               @relation("CatalogImportCreatedBy")
  clinicalAlertRulesUpdated   ClinicalAlertRule[]           @relation("ClinicalAlertRuleUpdatedBy")
  laboratoryCatalogsCreated   LaboratoryCatalog[]           @relation("LaboratoryCatalogCreatedBy")
  medicationsCreated          Medication[]                  @relation("MedicationCreatedBy")
  medicationLotsCreated       MedicationInventoryLot[]      @relation("MedicationLotCreatedBy")
  companyMemberships          UserCompanyMembership[]
  inventoryMovementsCreated   MedicationInventoryMovement[] @relation("InventoryMovementCreatedBy")

  pharmacySalesCreated     PharmacySale[]        @relation("PharmacySaleCreatedBy")
  pharmacySalesVoided      PharmacySale[]        @relation("PharmacySaleVoidedBy")
  pharmacyPricesApproved   PharmacySaleItem[]    @relation("PharmacySalePriceApprovedBy")
  pharmacyPaymentsRecorded PharmacySalePayment[] @relation("PharmacySalePaymentRecordedBy")

  commercialCustomersCreated      CommercialCustomer[]      @relation("CommercialCustomerCreatedBy")
  electronicDocumentsCreated      ElectronicDocument[]      @relation("ElectronicDocumentCreatedBy")
  electronicDocumentEventsCreated ElectronicDocumentEvent[] @relation("ElectronicDocumentEventCreatedBy")
  prescriptionReferralsCreated    PrescriptionReferral[]    @relation("PrescriptionReferralCreatedBy")
  prescriptionReferralsUpdated    PrescriptionReferral[]    @relation("PrescriptionReferralUpdatedBy")

  @@unique([tenantId, dni])
}

model Patient {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  fullName       String
  documentNumber String
  hceNumber      String?   @db.VarChar(30)
  documentType   String    @default("DNI")
  birthDate      DateTime?
  gender         String?
  phone          String?
  email          String?
  address        String?

  allergies       String?
  chronicDiseases String?
  usualMedication String?
  observations    String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  anamnesis     Anamnesis[]
  certificates  Certificate[]
  encounters    Encounter[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  pharmacySales PharmacySale[]

  @@unique([tenantId, hceNumber])
  @@index([tenantId])
  @@index([documentNumber])
  @@index([fullName])
}

model Encounter {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  patientId String @db.Uuid

  type   String? @default("consulta")
  reason String?
  status String  @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  anamnesis  Anamnesis[]
  vitalSigns VitalSigns?
}

model VitalSigns {
  id          String @id @default(uuid()) @db.Uuid
  encounterId String @unique @db.Uuid

  systolicBP      Int?
  diastolicBP     Int?
  heartRate       Int?
  respiratoryRate Int?
  temperature     Float?
  oxygenSat       Int?

  weightKg Float?
  heightCm Float?
  bmi      Float?

  capillaryGlucose Int?
  painScale        Int?

  consciousness String?
  glasgowEye    Int?
  glasgowVerbal Int?
  glasgowMotor  Int?
  glasgowTotal  Int?

  oxygenSupport String?
  fio2          Int?
  nursingNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model Establishment {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @unique @db.Uuid
  name         String
  address      String?
  phone        String?
  email        String?
  logoUrl      String?
  directorName String?
  directorCmp  String?
  directorRne  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  patientId       String   @db.Uuid
  issuedBy        String   @db.Uuid
  certificateType String   @default("REST_CERTIFICATE")
  diagnoses       String[]
  restDays        Int?
  observations    String?
  place           String?
  issueDate       DateTime
  pdfUrl          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  issuedByUser    User     @relation(fields: [issuedBy], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Anamnesis {
  id                      String         @id @default(uuid()) @db.Uuid
  tenantId                String         @db.Uuid
  patientId               String         @db.Uuid
  encounterId             String?        @db.Uuid
  fechaAtencion           DateTime
  motivoConsulta          String
  tiempoEnfermedad        String?
  anamnesisActual         String?
  funcionesBiologicas     String?
  antecedentesPersonales  String?
  antecedentesFamiliares  String?
  signosVitales           Json?
  examenFisico            String?
  diagnosticoPrincipal    Json?
  diagnosticosSecundarios Json?
  examenesAuxiliares      String?
  prescripcionesFarmacia  String?
  destinoFinal            String         @default("alta_medica")
  issuedBy                String?        @default("admin@amehealth.pe")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  encounter               Encounter?     @relation(fields: [encounterId], references: [id])
  patient                 Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant                  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions           Prescription[]
}

model Institution {
  id                            String   @id @default(uuid()) @db.Uuid
  tenantId                      String   @unique @db.Uuid
  name                          String?
  legalName                     String?
  ruc                           String?
  address                       String?
  phone                         String?
  email                         String?
  city                          String?  @default("Arequipa")
  country                       String?  @default("Perú")
  logoUrl                       String?
  primaryColor                  String?  @default("#0f766e")
  secondaryColor                String?  @default("#14b8a6")
  directorName                  String?
  directorCmp                   String?
  directorRne                   String?
  timezone                      String?  @default("America/Lima")
  language                      String?  @default("es")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  sealUrl                       String?
  signatureUrl                  String?
  logoHeight                    Int?     @default(70)
  logoWidth                     Int?     @default(70)
  sealHeight                    Int?     @default(70)
  sealWidth                     Int?     @default(120)
  signatureHeight               Int?     @default(70)
  signatureWidth                Int?     @default(180)
  altitudeMeters                Int      @default(0)
  spo2AltitudeAdjustmentEnabled Boolean  @default(false)
  spo2ReferenceProfile          String   @default("ADULT_ACCLIMATIZED")
  spo2ExpectedMin               Int      @default(95)
  spo2ExpectedMax               Int      @default(100)
  tenant                        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HceConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @unique @db.Uuid
  requireCie10           Boolean  @default(true)
  allowMultipleDiagnoses Boolean  @default(true)
  defaultRestDays        Int      @default(1)
  requireVitalSigns      Boolean  @default(true)
  autoSaveDrafts         Boolean  @default(true)
  signatureRequired      Boolean  @default(true)
  customFields           Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSystemModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String   @db.VarChar(40)
  enabled   Boolean  @default(false)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
}

model Medication {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  masterCode           String?  @db.VarChar(60)
  internalCode         String?  @db.VarChar(50)
  barcode              String?  @db.VarChar(80)
  productType          String   @default("MEDICAMENTO") @db.VarChar(40)
  genericName          String
  commercialName       String?
  concentration        String?
  pharmaceuticalForm   String?  @db.VarChar(150)
  presentation         String
  route                String?
  unitMeasure          String?  @db.VarChar(80)
  laboratory           String?  @db.VarChar(180)
  manufacturer         String?  @db.VarChar(180)
  registrationHolder   String?  @db.VarChar(180)
  sanitaryRegistration String?  @db.VarChar(100)
  atcCode              String?  @db.VarChar(30)
  pnumCode             String?  @db.VarChar(50)
  requiresPrescription Boolean  @default(true)
  controlled           Boolean  @default(false)
  coldChain            Boolean  @default(false)
  taxable              Boolean  @default(true)
  active               Boolean  @default(true)
  observations         String?  @db.Text
  searchText           String   @default("") @db.Text
  source               String?  @db.VarChar(255)
  createdById          String?  @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser      User?                         @relation("MedicationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  prescriptionItems  PrescriptionItem[]
  inventoryLots      MedicationInventoryLot[]
  companyProfiles    CompanyMedication[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySaleItems PharmacySaleItem[]

  @@unique([tenantId, internalCode])
  @@index([tenantId, masterCode])
  @@index([tenantId, active, productType])
  @@index([tenantId, barcode])
  @@index([tenantId, genericName])
  @@index([tenantId, commercialName])
}

model MedicationInventoryLot {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  medicationId   String    @db.Uuid
  businessUnit   String    @default("FARMACIA") @db.VarChar(30)
  warehouse      String    @default("PRINCIPAL") @db.VarChar(100)
  shelfCode      String?   @db.VarChar(60)
  shelfLevel     String?   @db.VarChar(60)
  locationNotes  String?   @db.VarChar(255)
  lotNumber      String    @default("SIN_LOTE") @db.VarChar(100)
  expirationDate DateTime?
  stock          Decimal   @default(0) @db.Decimal(14, 3)
  minimumStock   Decimal   @default(0) @db.Decimal(14, 3)
  purchasePrice  Decimal?  @db.Decimal(14, 4)
  salePrice      Decimal?  @db.Decimal(14, 4)
  wholesalePrice Decimal?  @db.Decimal(14, 4)
  currency       String    @default("PEN") @db.VarChar(3)
  supplier       String?   @db.VarChar(180)
  active         Boolean   @default(true)
  source         String?   @db.VarChar(255)
  createdById    String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant              Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medication          Medication                    @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  createdByUser       User?                         @relation("MedicationLotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companyId           String?                       @db.Uuid
  businessUnitId      String?                       @db.Uuid
  warehouseId         String?                       @db.Uuid
  companyMedicationId String?                       @db.Uuid
  company             Company?                      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  businessUnitEntity  BusinessUnit?                 @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  warehouseEntity     Warehouse?                    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  companyMedication   CompanyMedication?            @relation(fields: [companyMedicationId], references: [id], onDelete: SetNull)
  inventoryMovements  MedicationInventoryMovement[]

  pharmacySaleAllocations PharmacySaleItemAllocation[]

  @@unique([tenantId, medicationId, businessUnit, warehouse, lotNumber])
  @@index([tenantId, businessUnit, warehouse, active])
  @@index([tenantId, businessUnit, warehouse, shelfCode, shelfLevel])
  @@index([tenantId, expirationDate])
}

model Prescription {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @db.Uuid
  patientId   String             @db.Uuid
  anamnesisId String?            @db.Uuid
  issuedBy    String             @db.Uuid
  issueDate   DateTime           @default(now())
  notes       String?
  pdfUrl      String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  anamnesis   Anamnesis?         @relation(fields: [anamnesisId], references: [id])
  doctor      User               @relation(fields: [issuedBy], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       PrescriptionItem[]

  pharmacySales     PharmacySale[]
  companyId         String?                @db.Uuid
  businessUnitId    String?                @db.Uuid
  ownerCompany      Company?               @relation("PrescriptionOwnerCompany", fields: [companyId], references: [id], onDelete: SetNull)
  ownerBusinessUnit BusinessUnit?          @relation("PrescriptionOwnerBusinessUnit", fields: [businessUnitId], references: [id], onDelete: SetNull)
  referrals         PrescriptionReferral[]

  @@index([tenantId, companyId, businessUnitId])
}

model PrescriptionItem {
  id             String       @id @default(uuid()) @db.Uuid
  prescriptionId String       @db.Uuid
  medicationId   String       @db.Uuid
  quantity       Int
  route          String?
  dose           String?
  frequency      String?
  durationDays   Int?
  indications    String?
  createdAt      DateTime     @default(now())
  medication     Medication   @relation(fields: [medicationId], references: [id])
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  pharmacySaleItems PharmacySaleItem[]
}

model DiagnosisCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  system       String   @default("CIE10") @db.VarChar(10)
  code         String   @db.VarChar(20)
  description  String   @db.Text
  chapter      String?  @db.VarChar(255)
  group        String?  @db.VarChar(255)
  subgroup     String?  @db.VarChar(255)
  synonyms     String[] @default([])
  searchText   String   @default("") @db.Text
  active       Boolean  @default(true)
  observations String?  @db.Text
  source       String?  @db.VarChar(255)
  createdById  String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("DiagnosisCatalogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tenantId, system, code])
  @@index([tenantId, system, active])
  @@index([tenantId, code])
}

model CatalogImport {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  catalogType      String    @db.VarChar(30)
  sourceFileName   String    @db.VarChar(255)
  source           String?   @db.VarChar(255)
  status           String    @default("PENDING") @db.VarChar(20)
  totalRows        Int       @default(0)
  validRows        Int       @default(0)
  invalidRows      Int       @default(0)
  createdRows      Int       @default(0)
  updatedRows      Int       @default(0)
  skippedRows      Int       @default(0)
  errorRows        Int       @default(0)
  validationReport Json?
  createdById      String?   @db.Uuid
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("CatalogImportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, catalogType, createdAt])
  @@index([tenantId, status])
}

model LaboratoryCatalog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  code            String   @db.VarChar(30)
  name            String   @db.Text
  nameKey         String   @db.VarChar(500)
  category        String   @db.VarChar(150)
  subcategory     String?  @db.VarChar(150)
  shortName       String?  @db.VarChar(150)
  specimenType    String?  @db.VarChar(150)
  unit            String?  @db.VarChar(80)
  referenceValue  String?  @db.Text
  method          String?  @db.VarChar(255)
  price           Decimal? @db.Decimal(10, 2)
  requiresFasting Boolean  @default(false)
  isProfile       Boolean  @default(false)
  active          Boolean  @default(true)
  observations    String?  @db.Text
  searchText      String   @default("") @db.Text
  source          String?  @db.VarChar(255)
  createdById     String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser     User?                        @relation("LaboratoryCatalogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  profileComponents LaboratoryProfileComponent[] @relation("LaboratoryProfile")
  componentOf       LaboratoryProfileComponent[] @relation("LaboratoryComponent")

  @@unique([tenantId, code, nameKey])
  @@index([tenantId, active, category])
  @@index([tenantId, code])
  @@index([tenantId, nameKey])
}

model LaboratoryProfileComponent {
  profileId   String   @db.Uuid
  componentId String   @db.Uuid
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  profile   LaboratoryCatalog @relation("LaboratoryProfile", fields: [profileId], references: [id], onDelete: Cascade)
  component LaboratoryCatalog @relation("LaboratoryComponent", fields: [componentId], references: [id], onDelete: Cascade)

  @@id([profileId, componentId])
  @@index([componentId])
}

model ClinicalAlertRule {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  key           String   @db.VarChar(80)
  name          String   @db.VarChar(160)
  abbreviation  String   @db.VarChar(20)
  category      String   @default("vital_signs") @db.VarChar(40)
  sourceType    String   @default("VITAL_SIGNS") @db.VarChar(40)
  displayFields String[] @default([])
  unit          String?  @db.VarChar(30)
  referenceKey  String?  @db.VarChar(80)
  sourceNote    String?  @db.Text
  active        Boolean  @default(true)
  displayOrder  Int      @default(0)
  version       Int      @default(1)
  updatedById   String?  @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?               @relation("ClinicalAlertRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  bands         ClinicalAlertBand[]

  @@unique([tenantId, key])
  @@index([tenantId, active, displayOrder])
  @@index([tenantId, sourceType])
}

model ClinicalAlertBand {
  id              String   @id @default(uuid()) @db.Uuid
  ruleId          String   @db.Uuid
  key             String   @db.VarChar(80)
  severity        String   @db.VarChar(20)
  label           String   @db.VarChar(100)
  symbol          String?  @db.VarChar(10)
  colorHex        String?  @db.VarChar(9)
  matchMode       String   @default("ALL") @db.VarChar(10)
  messageTemplate String   @db.Text
  suggestedAction String?  @db.Text
  active          Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rule       ClinicalAlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  conditions ClinicalAlertCondition[]

  @@unique([ruleId, key])
  @@index([ruleId, active, priority])
}

model ClinicalAlertCondition {
  id          String   @id @default(uuid()) @db.Uuid
  bandId      String   @db.Uuid
  sourceField String   @db.VarChar(80)
  operator    String   @db.VarChar(20)
  value1      Float
  value2      Float?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  band ClinicalAlertBand @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@index([bandId, order])
}

model Company {
  id                          String                     @id @default(uuid()) @db.Uuid
  tenantId                    String                     @db.Uuid
  code                        String                     @db.VarChar(30)
  legalName                   String                     @db.VarChar(180)
  tradeName                   String?                    @db.VarChar(180)
  ruc                         String                     @db.VarChar(11)
  active                      Boolean                    @default(true)
  status                      AdministrativeEntityStatus @default(ACTIVE)
  suspendedAt                 DateTime?
