// Archivo: schema.prisma
// Ruta: apps/api/prisma/schema.prisma
// Función: Esquema principal de datos de HCELM.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                     String                        @id @default(uuid()) @db.Uuid
  name                   String
  ruc                    String                        @unique
  active                 Boolean                       @default(true)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  anamnesis              Anamnesis[]
  certificates           Certificate[]
  encounters             Encounter[]
  establishments         Establishment?
  hceConfigs             HceConfig?
  institutions           Institution?
  medications            Medication[]
  medicationLots         MedicationInventoryLot[]
  patients               Patient[]
  prescriptions          Prescription[]
  users                  User[]
  diagnosisCatalogs      DiagnosisCatalog[]
  catalogImports         CatalogImport[]
  clinicalAlertRules     ClinicalAlertRule[]
  laboratoryCatalogs     LaboratoryCatalog[]
  systemModules          TenantSystemModule[]
  companies              Company[]
  businessUnits          BusinessUnit[]
  warehouses             Warehouse[]
  companyMedications     CompanyMedication[]
  userCompanyMemberships UserCompanyMembership[]
  inventoryMovements     MedicationInventoryMovement[]

  pharmacySales             PharmacySale[]
  pharmacySaleItems         PharmacySaleItem[]
  pharmacySaleAllocations   PharmacySaleItemAllocation[]
  pharmacySalePayments      PharmacySalePayment[]
  pharmacyDocumentSequences PharmacyDocumentSequence[]
}

model User {
  id                        String                        @id @default(uuid()) @db.Uuid
  tenantId                  String                        @db.Uuid
  email                     String
  password                  String
  fullName                  String?
  role                      String                        @default("medico")
  cmp                       String?
  rne                       String?
  active                    Boolean                       @default(true)
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  certificates              Certificate[]
  prescriptions             Prescription[]
  tenant                    Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  diagnosisCatalogsCreated  DiagnosisCatalog[]            @relation("DiagnosisCatalogCreatedBy")
  catalogImports            CatalogImport[]               @relation("CatalogImportCreatedBy")
  clinicalAlertRulesUpdated ClinicalAlertRule[]           @relation("ClinicalAlertRuleUpdatedBy")
  laboratoryCatalogsCreated LaboratoryCatalog[]           @relation("LaboratoryCatalogCreatedBy")
  medicationsCreated        Medication[]                  @relation("MedicationCreatedBy")
  medicationLotsCreated     MedicationInventoryLot[]      @relation("MedicationLotCreatedBy")
  companyMemberships        UserCompanyMembership[]
  inventoryMovementsCreated MedicationInventoryMovement[] @relation("InventoryMovementCreatedBy")

  pharmacySalesCreated     PharmacySale[]        @relation("PharmacySaleCreatedBy")
  pharmacySalesVoided      PharmacySale[]        @relation("PharmacySaleVoidedBy")
  pharmacyPricesApproved   PharmacySaleItem[]    @relation("PharmacySalePriceApprovedBy")
  pharmacyPaymentsRecorded PharmacySalePayment[] @relation("PharmacySalePaymentRecordedBy")
}

model Patient {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  fullName       String
  documentNumber String
  hceNumber      String?   @db.VarChar(30)
  documentType   String    @default("DNI")
  birthDate      DateTime?
  gender         String?
  phone          String?
  email          String?
  address        String?

  allergies       String?
  chronicDiseases String?
  usualMedication String?
  observations    String?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  anamnesis     Anamnesis[]
  certificates  Certificate[]
  encounters    Encounter[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]

  pharmacySales PharmacySale[]

  @@unique([tenantId, hceNumber])
  @@index([tenantId])
  @@index([documentNumber])
  @@index([fullName])
}

model Encounter {
  id        String @id @default(uuid()) @db.Uuid
  tenantId  String @db.Uuid
  patientId String @db.Uuid

  type   String? @default("consulta")
  reason String?
  status String  @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  anamnesis  Anamnesis[]
  vitalSigns VitalSigns?
}

model VitalSigns {
  id          String @id @default(uuid()) @db.Uuid
  encounterId String @unique @db.Uuid

  systolicBP      Int?
  diastolicBP     Int?
  heartRate       Int?
  respiratoryRate Int?
  temperature     Float?
  oxygenSat       Int?

  weightKg Float?
  heightCm Float?
  bmi      Float?

  capillaryGlucose Int?
  painScale        Int?

  consciousness String?
  glasgowEye    Int?
  glasgowVerbal Int?
  glasgowMotor  Int?
  glasgowTotal  Int?

  oxygenSupport String?
  fio2          Int?
  nursingNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  encounter Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)
}

model Establishment {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @unique @db.Uuid
  name         String
  address      String?
  phone        String?
  email        String?
  logoUrl      String?
  directorName String?
  directorCmp  String?
  directorRne  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  patientId       String   @db.Uuid
  issuedBy        String   @db.Uuid
  certificateType String   @default("REST_CERTIFICATE")
  diagnoses       String[]
  restDays        Int?
  observations    String?
  place           String?
  issueDate       DateTime
  pdfUrl          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  issuedByUser    User     @relation(fields: [issuedBy], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Anamnesis {
  id                      String         @id @default(uuid()) @db.Uuid
  tenantId                String         @db.Uuid
  patientId               String         @db.Uuid
  encounterId             String?        @db.Uuid
  fechaAtencion           DateTime
  motivoConsulta          String
  tiempoEnfermedad        String?
  anamnesisActual         String?
  funcionesBiologicas     String?
  antecedentesPersonales  String?
  antecedentesFamiliares  String?
  signosVitales           Json?
  examenFisico            String?
  diagnosticoPrincipal    Json?
  diagnosticosSecundarios Json?
  examenesAuxiliares      String?
  prescripcionesFarmacia  String?
  destinoFinal            String         @default("alta_medica")
  issuedBy                String?        @default("admin@amehealth.pe")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  encounter               Encounter?     @relation(fields: [encounterId], references: [id])
  patient                 Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant                  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescriptions           Prescription[]
}

model Institution {
  id                            String   @id @default(uuid()) @db.Uuid
  tenantId                      String   @unique @db.Uuid
  name                          String?
  legalName                     String?
  ruc                           String?
  address                       String?
  phone                         String?
  email                         String?
  city                          String?  @default("Arequipa")
  country                       String?  @default("Perú")
  logoUrl                       String?
  primaryColor                  String?  @default("#0f766e")
  secondaryColor                String?  @default("#14b8a6")
  directorName                  String?
  directorCmp                   String?
  directorRne                   String?
  timezone                      String?  @default("America/Lima")
  language                      String?  @default("es")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  sealUrl                       String?
  signatureUrl                  String?
  logoHeight                    Int?     @default(70)
  logoWidth                     Int?     @default(70)
  sealHeight                    Int?     @default(70)
  sealWidth                     Int?     @default(120)
  signatureHeight               Int?     @default(70)
  signatureWidth                Int?     @default(180)
  altitudeMeters                Int      @default(0)
  spo2AltitudeAdjustmentEnabled Boolean  @default(false)
  spo2ReferenceProfile          String   @default("ADULT_ACCLIMATIZED")
  spo2ExpectedMin               Int      @default(95)
  spo2ExpectedMax               Int      @default(100)
  tenant                        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model HceConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  tenantId               String   @unique @db.Uuid
  requireCie10           Boolean  @default(true)
  allowMultipleDiagnoses Boolean  @default(true)
  defaultRestDays        Int      @default(1)
  requireVitalSigns      Boolean  @default(true)
  autoSaveDrafts         Boolean  @default(true)
  signatureRequired      Boolean  @default(true)
  customFields           Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantSystemModule {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  key       String   @db.VarChar(40)
  enabled   Boolean  @default(false)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
}

model Medication {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  masterCode           String?  @db.VarChar(60)
  internalCode         String?  @db.VarChar(50)
  barcode              String?  @db.VarChar(80)
  productType          String   @default("MEDICAMENTO") @db.VarChar(40)
  genericName          String
  commercialName       String?
  concentration        String?
  pharmaceuticalForm   String?  @db.VarChar(150)
  presentation         String
  route                String?
  unitMeasure          String?  @db.VarChar(80)
  laboratory           String?  @db.VarChar(180)
  manufacturer         String?  @db.VarChar(180)
  registrationHolder   String?  @db.VarChar(180)
  sanitaryRegistration String?  @db.VarChar(100)
  atcCode              String?  @db.VarChar(30)
  pnumCode             String?  @db.VarChar(50)
  requiresPrescription Boolean  @default(true)
  controlled           Boolean  @default(false)
  coldChain            Boolean  @default(false)
  taxable              Boolean  @default(true)
  active               Boolean  @default(true)
  observations         String?  @db.Text
  searchText           String   @default("") @db.Text
  source               String?  @db.VarChar(255)
  createdById          String?  @db.Uuid
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser      User?                         @relation("MedicationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  prescriptionItems  PrescriptionItem[]
  inventoryLots      MedicationInventoryLot[]
  companyProfiles    CompanyMedication[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySaleItems PharmacySaleItem[]

  @@unique([tenantId, internalCode])
  @@index([tenantId, masterCode])
  @@index([tenantId, active, productType])
  @@index([tenantId, barcode])
  @@index([tenantId, genericName])
  @@index([tenantId, commercialName])
}

model MedicationInventoryLot {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid
  medicationId   String    @db.Uuid
  businessUnit   String    @default("FARMACIA") @db.VarChar(30)
  warehouse      String    @default("PRINCIPAL") @db.VarChar(100)
  shelfCode      String?   @db.VarChar(60)
  shelfLevel     String?   @db.VarChar(60)
  locationNotes  String?   @db.VarChar(255)
  lotNumber      String    @default("SIN_LOTE") @db.VarChar(100)
  expirationDate DateTime?
  stock          Decimal   @default(0) @db.Decimal(14, 3)
  minimumStock   Decimal   @default(0) @db.Decimal(14, 3)
  purchasePrice  Decimal?  @db.Decimal(14, 4)
  salePrice      Decimal?  @db.Decimal(14, 4)
  wholesalePrice Decimal?  @db.Decimal(14, 4)
  currency       String    @default("PEN") @db.VarChar(3)
  supplier       String?   @db.VarChar(180)
  active         Boolean   @default(true)
  source         String?   @db.VarChar(255)
  createdById    String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant              Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  medication          Medication                    @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  createdByUser       User?                         @relation("MedicationLotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  companyId           String?                       @db.Uuid
  businessUnitId      String?                       @db.Uuid
  warehouseId         String?                       @db.Uuid
  companyMedicationId String?                       @db.Uuid
  company             Company?                      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  businessUnitEntity  BusinessUnit?                 @relation(fields: [businessUnitId], references: [id], onDelete: SetNull)
  warehouseEntity     Warehouse?                    @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  companyMedication   CompanyMedication?            @relation(fields: [companyMedicationId], references: [id], onDelete: SetNull)
  inventoryMovements  MedicationInventoryMovement[]

  pharmacySaleAllocations PharmacySaleItemAllocation[]

  @@unique([tenantId, medicationId, businessUnit, warehouse, lotNumber])
  @@index([tenantId, businessUnit, warehouse, active])
  @@index([tenantId, businessUnit, warehouse, shelfCode, shelfLevel])
  @@index([tenantId, expirationDate])
}

model Prescription {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @db.Uuid
  patientId   String             @db.Uuid
  anamnesisId String?            @db.Uuid
  issuedBy    String             @db.Uuid
  issueDate   DateTime           @default(now())
  notes       String?
  pdfUrl      String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  anamnesis   Anamnesis?         @relation(fields: [anamnesisId], references: [id])
  doctor      User               @relation(fields: [issuedBy], references: [id])
  patient     Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       PrescriptionItem[]

  pharmacySales PharmacySale[]
}

model PrescriptionItem {
  id             String       @id @default(uuid()) @db.Uuid
  prescriptionId String       @db.Uuid
  medicationId   String       @db.Uuid
  quantity       Int
  route          String?
  dose           String?
  frequency      String?
  durationDays   Int?
  indications    String?
  createdAt      DateTime     @default(now())
  medication     Medication   @relation(fields: [medicationId], references: [id])
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  pharmacySaleItems PharmacySaleItem[]
}

model DiagnosisCatalog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  system       String   @default("CIE10") @db.VarChar(10)
  code         String   @db.VarChar(20)
  description  String   @db.Text
  chapter      String?  @db.VarChar(255)
  group        String?  @db.VarChar(255)
  subgroup     String?  @db.VarChar(255)
  synonyms     String[] @default([])
  searchText   String   @default("") @db.Text
  active       Boolean  @default(true)
  observations String?  @db.Text
  source       String?  @db.VarChar(255)
  createdById  String?  @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("DiagnosisCatalogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([tenantId, system, code])
  @@index([tenantId, system, active])
  @@index([tenantId, code])
}

model CatalogImport {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @db.Uuid
  catalogType      String    @db.VarChar(30)
  sourceFileName   String    @db.VarChar(255)
  source           String?   @db.VarChar(255)
  status           String    @default("PENDING") @db.VarChar(20)
  totalRows        Int       @default(0)
  validRows        Int       @default(0)
  invalidRows      Int       @default(0)
  createdRows      Int       @default(0)
  updatedRows      Int       @default(0)
  skippedRows      Int       @default(0)
  errorRows        Int       @default(0)
  validationReport Json?
  createdById      String?   @db.Uuid
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("CatalogImportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, catalogType, createdAt])
  @@index([tenantId, status])
}

model LaboratoryCatalog {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid
  code            String   @db.VarChar(30)
  name            String   @db.Text
  nameKey         String   @db.VarChar(500)
  category        String   @db.VarChar(150)
  subcategory     String?  @db.VarChar(150)
  shortName       String?  @db.VarChar(150)
  specimenType    String?  @db.VarChar(150)
  unit            String?  @db.VarChar(80)
  referenceValue  String?  @db.Text
  method          String?  @db.VarChar(255)
  price           Decimal? @db.Decimal(10, 2)
  requiresFasting Boolean  @default(false)
  isProfile       Boolean  @default(false)
  active          Boolean  @default(true)
  observations    String?  @db.Text
  searchText      String   @default("") @db.Text
  source          String?  @db.VarChar(255)
  createdById     String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser     User?                        @relation("LaboratoryCatalogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  profileComponents LaboratoryProfileComponent[] @relation("LaboratoryProfile")
  componentOf       LaboratoryProfileComponent[] @relation("LaboratoryComponent")

  @@unique([tenantId, code, nameKey])
  @@index([tenantId, active, category])
  @@index([tenantId, code])
  @@index([tenantId, nameKey])
}

model LaboratoryProfileComponent {
  profileId   String   @db.Uuid
  componentId String   @db.Uuid
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  profile   LaboratoryCatalog @relation("LaboratoryProfile", fields: [profileId], references: [id], onDelete: Cascade)
  component LaboratoryCatalog @relation("LaboratoryComponent", fields: [componentId], references: [id], onDelete: Cascade)

  @@id([profileId, componentId])
  @@index([componentId])
}

model ClinicalAlertRule {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid
  key           String   @db.VarChar(80)
  name          String   @db.VarChar(160)
  abbreviation  String   @db.VarChar(20)
  category      String   @default("vital_signs") @db.VarChar(40)
  sourceType    String   @default("VITAL_SIGNS") @db.VarChar(40)
  displayFields String[] @default([])
  unit          String?  @db.VarChar(30)
  referenceKey  String?  @db.VarChar(80)
  sourceNote    String?  @db.Text
  active        Boolean  @default(true)
  displayOrder  Int      @default(0)
  version       Int      @default(1)
  updatedById   String?  @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedByUser User?               @relation("ClinicalAlertRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  bands         ClinicalAlertBand[]

  @@unique([tenantId, key])
  @@index([tenantId, active, displayOrder])
  @@index([tenantId, sourceType])
}

model ClinicalAlertBand {
  id              String   @id @default(uuid()) @db.Uuid
  ruleId          String   @db.Uuid
  key             String   @db.VarChar(80)
  severity        String   @db.VarChar(20)
  label           String   @db.VarChar(100)
  symbol          String?  @db.VarChar(10)
  colorHex        String?  @db.VarChar(9)
  matchMode       String   @default("ALL") @db.VarChar(10)
  messageTemplate String   @db.Text
  suggestedAction String?  @db.Text
  active          Boolean  @default(true)
  priority        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rule       ClinicalAlertRule        @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  conditions ClinicalAlertCondition[]

  @@unique([ruleId, key])
  @@index([ruleId, active, priority])
}

model ClinicalAlertCondition {
  id          String   @id @default(uuid()) @db.Uuid
  bandId      String   @db.Uuid
  sourceField String   @db.VarChar(80)
  operator    String   @db.VarChar(20)
  value1      Float
  value2      Float?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  band ClinicalAlertBand @relation(fields: [bandId], references: [id], onDelete: Cascade)

  @@index([bandId, order])
}

model Company {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  code      String   @db.VarChar(30)
  legalName String   @db.VarChar(180)
  tradeName String?  @db.VarChar(180)
  ruc       String   @db.VarChar(11)
  active    Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnits      BusinessUnit[]
  warehouses         Warehouse[]
  medicationProfiles CompanyMedication[]
  userMemberships    UserCompanyMembership[]
  inventoryLots      MedicationInventoryLot[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySales             PharmacySale[]
  pharmacyDocumentSequences PharmacyDocumentSequence[]

  @@unique([tenantId, code])
  @@unique([tenantId, ruc])
  @@index([tenantId, active])
}

model BusinessUnit {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  companyId String   @db.Uuid
  code      String   @db.VarChar(40)
  name      String   @db.VarChar(160)
  type      String   @db.VarChar(40)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  warehouses         Warehouse[]
  inventoryLots      MedicationInventoryLot[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySales             PharmacySale[]
  pharmacyDocumentSequences PharmacyDocumentSequence[]

  @@unique([companyId, code])
  @@index([tenantId, companyId, active])
}

model Warehouse {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  companyId      String   @db.Uuid
  businessUnitId String   @db.Uuid
  code           String   @db.VarChar(60)
  name           String   @db.VarChar(160)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit       BusinessUnit                  @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  inventoryLots      MedicationInventoryLot[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySales             PharmacySale[]
  pharmacyDocumentSequences PharmacyDocumentSequence[]

  @@unique([businessUnitId, code])
  @@index([tenantId, companyId, businessUnitId, active])
}

model CompanyMedication {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  companyId    String   @db.Uuid
  medicationId String   @db.Uuid
  companySku   String?  @db.VarChar(60)
  barcode      String?  @db.VarChar(80)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant             Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company            Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  medication         Medication                    @relation(fields: [medicationId], references: [id], onDelete: Restrict)
  inventoryLots      MedicationInventoryLot[]
  inventoryMovements MedicationInventoryMovement[]

  pharmacySaleItems PharmacySaleItem[]

  @@unique([companyId, medicationId])
  @@unique([companyId, companySku])
  @@index([tenantId, companyId, active])
  @@index([tenantId, barcode])
}

model UserCompanyMembership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String   @db.Uuid
  companyId String   @db.Uuid
  role      String   @default("USER") @db.VarChar(40)
  isDefault Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([tenantId, companyId, active])
}

enum MedicationInventoryMovementType {
  INITIAL_STOCK
  PURCHASE
  SALE
  PRESCRIPTION_DISPENSING
  POSITIVE_ADJUSTMENT
  NEGATIVE_ADJUSTMENT
  CUSTOMER_RETURN
  SUPPLIER_RETURN
  TRANSFER_IN
  TRANSFER_OUT
  REVERSAL
}

enum MedicationInventoryMovementDirection {
  IN
  OUT
}

model MedicationInventoryMovement {
  id                  String                               @id @default(uuid()) @db.Uuid
  tenantId            String                               @db.Uuid
  companyId           String                               @db.Uuid
  businessUnitId      String                               @db.Uuid
  warehouseId         String                               @db.Uuid
  medicationId        String                               @db.Uuid
  companyMedicationId String                               @db.Uuid
  lotId               String                               @db.Uuid
  movementType        MedicationInventoryMovementType
  direction           MedicationInventoryMovementDirection
  quantity            Decimal                              @db.Decimal(14, 3)
  stockBefore         Decimal                              @db.Decimal(14, 3)
  stockAfter          Decimal                              @db.Decimal(14, 3)
  unitCost            Decimal?                             @db.Decimal(14, 4)
  unitPrice           Decimal?                             @db.Decimal(14, 4)
  currency            String                               @default("PEN") @db.VarChar(3)
  operationId         String                               @db.Uuid
  idempotencyKey      String                               @db.VarChar(180)
  sourceType          String?                              @db.VarChar(40)
  sourceId            String?                              @db.VarChar(100)
  sourceLineId        String?                              @db.VarChar(100)
  documentType        String?                              @db.VarChar(40)
  documentNumber      String?                              @db.VarChar(100)
  reason              String?                              @db.Text
  metadata            Json?
  reversalOfId        String?                              @unique @db.Uuid
  createdById         String?                              @db.Uuid
  createdAt           DateTime                             @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company           Company                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit      BusinessUnit                 @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  warehouse         Warehouse                    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  medication        Medication                   @relation(fields: [medicationId], references: [id], onDelete: Restrict)
  companyMedication CompanyMedication            @relation(fields: [companyMedicationId], references: [id], onDelete: Restrict)
  lot               MedicationInventoryLot       @relation(fields: [lotId], references: [id], onDelete: Restrict)
  createdBy         User?                        @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reversalOf        MedicationInventoryMovement? @relation("InventoryMovementReversal", fields: [reversalOfId], references: [id], onDelete: Restrict)
  reversedBy        MedicationInventoryMovement? @relation("InventoryMovementReversal")

  pharmacySaleAllocation PharmacySaleItemAllocation?

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, companyId, warehouseId, createdAt])
  @@index([tenantId, medicationId, createdAt])
  @@index([tenantId, lotId, createdAt])
  @@index([tenantId, operationId])
  @@index([tenantId, sourceType, sourceId])
}

enum PharmacySaleType {
  OTC
  PRESCRIPTION
}

enum PharmacySaleStatus {
  COMPLETED
  VOIDED
  PARTIALLY_REFUNDED
  REFUNDED
}

enum PharmacyPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum PharmacyPaymentMethod {
  CASH
  CARD
  YAPE
  PLIN
  BANK_TRANSFER
  OTHER
}

enum PharmacyDocumentType {
  INTERNAL_SALE
}

model PharmacyDocumentSequence {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @db.Uuid
  companyId      String               @db.Uuid
  businessUnitId String               @db.Uuid
  warehouseId    String               @db.Uuid
  documentType   PharmacyDocumentType @default(INTERNAL_SALE)
  series         String               @db.VarChar(10)
  currentNumber  Int                  @default(0)
  active         Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([companyId, businessUnitId, warehouseId, documentType, series])
  @@index([tenantId, companyId, businessUnitId, warehouseId, active])
}

model PharmacySale {
  id                     String                @id @default(uuid()) @db.Uuid
  tenantId               String                @db.Uuid
  companyId              String                @db.Uuid
  businessUnitId         String                @db.Uuid
  warehouseId            String                @db.Uuid
  saleNumber             String                @db.VarChar(40)
  series                 String                @db.VarChar(10)
  sequenceNumber         Int
  saleType               PharmacySaleType
  status                 PharmacySaleStatus    @default(COMPLETED)
  patientId              String?               @db.Uuid
  prescriptionId         String?               @db.Uuid
  customerName           String?               @db.VarChar(180)
  customerDocumentType   String?               @db.VarChar(20)
  customerDocumentNumber String?               @db.VarChar(30)
  currency               String                @default("PEN") @db.VarChar(3)
  subtotal               Decimal               @db.Decimal(14, 4)
  discountTotal          Decimal               @default(0) @db.Decimal(14, 4)
  taxTotal               Decimal               @default(0) @db.Decimal(14, 4)
  total                  Decimal               @db.Decimal(14, 4)
  paymentStatus          PharmacyPaymentStatus @default(PAID)
  idempotencyKey         String                @db.VarChar(180)
  notes                  String?               @db.Text
  createdById            String                @db.Uuid
  completedAt            DateTime              @default(now())
  voidedAt               DateTime?
  voidedById             String?               @db.Uuid
  voidReason             String?               @db.Text
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company      Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit BusinessUnit          @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  patient      Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  prescription Prescription?         @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  createdBy    User                  @relation("PharmacySaleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  voidedBy     User?                 @relation("PharmacySaleVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  items        PharmacySaleItem[]
  payments     PharmacySalePayment[]

  @@unique([tenantId, idempotencyKey])
  @@unique([companyId, saleNumber])
  @@unique([companyId, businessUnitId, warehouseId, series, sequenceNumber])
  @@index([tenantId, companyId, businessUnitId, warehouseId, completedAt])
  @@index([tenantId, patientId, completedAt])
  @@index([tenantId, prescriptionId])
  @@index([tenantId, status, completedAt])
}

model PharmacySaleItem {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @db.Uuid
  saleId               String   @db.Uuid
  medicationId         String   @db.Uuid
  companyMedicationId  String   @db.Uuid
  prescriptionItemId   String?  @db.Uuid
  companySku           String?  @db.VarChar(60)
  genericName          String   @db.VarChar(180)
  commercialName       String?  @db.VarChar(180)
  concentration        String?  @db.VarChar(100)
  presentation         String   @db.VarChar(180)
  quantity             Decimal  @db.Decimal(14, 3)
  unitPrice            Decimal  @db.Decimal(14, 4)
  discountPercent      Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount       Decimal  @default(0) @db.Decimal(14, 4)
  taxAmount            Decimal  @default(0) @db.Decimal(14, 4)
  subtotal             Decimal  @db.Decimal(14, 4)
  total                Decimal  @db.Decimal(14, 4)
  requiresPrescription Boolean  @default(false)
  priceOverride        Boolean  @default(false)
  priceOverrideReason  String?  @db.Text
  priceApprovedById    String?  @db.Uuid
  createdAt            DateTime @default(now())

  tenant            Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sale              PharmacySale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  medication        Medication                   @relation(fields: [medicationId], references: [id], onDelete: Restrict)
  companyMedication CompanyMedication            @relation(fields: [companyMedicationId], references: [id], onDelete: Restrict)
  prescriptionItem  PrescriptionItem?            @relation(fields: [prescriptionItemId], references: [id], onDelete: SetNull)
  priceApprovedBy   User?                        @relation("PharmacySalePriceApprovedBy", fields: [priceApprovedById], references: [id], onDelete: SetNull)
  allocations       PharmacySaleItemAllocation[]

  @@index([tenantId, saleId])
  @@index([tenantId, medicationId, createdAt])
  @@index([tenantId, prescriptionItemId])
}

model PharmacySaleItemAllocation {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId            String    @db.Uuid
  saleItemId          String    @db.Uuid
  lotId               String    @db.Uuid
  inventoryMovementId String    @unique @db.Uuid
  lotNumber           String    @db.VarChar(100)
  expirationDate      DateTime?
  quantity            Decimal   @db.Decimal(14, 3)
  unitCost            Decimal?  @db.Decimal(14, 4)
  unitPrice           Decimal   @db.Decimal(14, 4)
  createdAt           DateTime  @default(now())

  tenant            Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  saleItem          PharmacySaleItem            @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  lot               MedicationInventoryLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  inventoryMovement MedicationInventoryMovement @relation(fields: [inventoryMovementId], references: [id], onDelete: Restrict)

  @@index([tenantId, saleItemId])
  @@index([tenantId, lotId, createdAt])
}

model PharmacySalePayment {
  id             String                @id @default(uuid()) @db.Uuid
  tenantId       String                @db.Uuid
  saleId         String                @db.Uuid
  method         PharmacyPaymentMethod
  amount         Decimal               @db.Decimal(14, 4)
  reference      String?               @db.VarChar(100)
  receivedAmount Decimal?              @db.Decimal(14, 4)
  changeAmount   Decimal?              @db.Decimal(14, 4)
  idempotencyKey String                @db.VarChar(180)
  paidAt         DateTime              @default(now())
  recordedById   String?               @db.Uuid
  createdAt      DateTime              @default(now())

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sale       PharmacySale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  recordedBy User?        @relation("PharmacySalePaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, saleId, paidAt])
  @@index([tenantId, method, paidAt])
}
