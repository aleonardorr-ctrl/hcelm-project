  xmlHash                  String?                      @db.VarChar(128)
  qrPayload                String?                      @db.Text
  sunatTicket              String?                      @db.VarChar(100)
  sunatResponseCode        String?                      @db.VarChar(20)
  sunatResponseDescription String?                      @db.Text
  submittedAt              DateTime?
  acceptedAt               DateTime?
  createdById              String                       @db.Uuid
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

  tenant           Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  company          Company                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit     BusinessUnit                 @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  warehouse        Warehouse                    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  sale             PharmacySale?                @relation(fields: [saleId], references: [id], onDelete: Restrict)
  customer         CommercialCustomer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  relatedDocument  ElectronicDocument?          @relation("ElectronicDocumentRelated", fields: [relatedDocumentId], references: [id], onDelete: Restrict)
  relatedDocuments ElectronicDocument[]         @relation("ElectronicDocumentRelated")
  createdBy        User                         @relation("ElectronicDocumentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines            ElectronicDocumentLine[]
  deliveries       ElectronicDocumentDelivery[]
  events           ElectronicDocumentEvent[]
  jobs             ElectronicDocumentJob[]

  @@unique([tenantId, idempotencyKey])
  @@unique([companyId, documentType, series, number])
  @@unique([companyId, fullNumber])
  @@index([tenantId, companyId, status, issueDate])
  @@index([tenantId, saleId])
  @@index([tenantId, customerId, issueDate])
  @@index([tenantId, relatedDocumentId])
}

model ElectronicDocumentLine {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  documentId         String   @db.Uuid
  saleItemId         String?  @db.Uuid
  lineNumber         Int
  companySku         String?  @db.VarChar(60)
  sunatProductCode   String?  @db.VarChar(20)
  gtin               String?  @db.VarChar(20)
  description        String   @db.VarChar(500)
  unitCode           String   @db.VarChar(3)
  quantity           Decimal  @db.Decimal(14, 3)
  unitValue          Decimal  @db.Decimal(14, 4)
  unitPrice          Decimal  @db.Decimal(14, 4)
  discountAmount     Decimal  @default(0) @db.Decimal(14, 4)
  taxAffectationCode String   @db.VarChar(2)
  taxRate            Decimal  @default(0) @db.Decimal(5, 2)
  igvAmount          Decimal  @default(0) @db.Decimal(14, 4)
  lineValue          Decimal  @db.Decimal(14, 4)
  lineTotal          Decimal  @db.Decimal(14, 4)
  createdAt          DateTime @default(now())

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  document ElectronicDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  saleItem PharmacySaleItem?  @relation(fields: [saleItemId], references: [id], onDelete: SetNull)

  @@unique([documentId, lineNumber])
  @@index([tenantId, documentId])
  @@index([tenantId, saleItemId])
}

model ElectronicDocumentDelivery {
  id                String                    @id @default(uuid()) @db.Uuid
  tenantId          String                    @db.Uuid
  documentId        String                    @db.Uuid
  channel           ElectronicDeliveryChannel
  destination       String                    @db.VarChar(255)
  recipientName     String?                   @db.VarChar(200)
  status            ElectronicDeliveryStatus  @default(PENDING)
  idempotencyKey    String                    @db.VarChar(180)
  consentAt         DateTime?
  attempts          Int                       @default(0)
  providerMessageId String?                   @db.VarChar(255)
  lastError         String?                   @db.Text
  sentAt            DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  document ElectronicDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, documentId, status])
  @@index([tenantId, channel, status, createdAt])
}

model ElectronicDocumentEvent {
  id          String                    @id @default(uuid()) @db.Uuid
  tenantId    String                    @db.Uuid
  documentId  String                    @db.Uuid
  status      ElectronicDocumentStatus?
  eventType   String                    @db.VarChar(60)
  message     String?                   @db.Text
  payload     Json?
  createdById String?                   @db.Uuid
  createdAt   DateTime                  @default(now())

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  document  ElectronicDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User?              @relation("ElectronicDocumentEventCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, documentId, createdAt])
  @@index([tenantId, eventType, createdAt])
}

model ElectronicDocumentJob {
  id             String                      @id @default(uuid()) @db.Uuid
  tenantId       String                      @db.Uuid
  documentId     String                      @db.Uuid
  jobType        ElectronicDocumentJobType
  status         ElectronicDocumentJobStatus @default(PENDING)
  idempotencyKey String                      @db.VarChar(180)
  payload        Json?
  attempts       Int                         @default(0)
  maxAttempts    Int                         @default(5)
  nextAttemptAt  DateTime                    @default(now())
  lockedAt       DateTime?
  lockedBy       String?                     @db.VarChar(100)
  lastError      String?                     @db.Text
  completedAt    DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  document ElectronicDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, nextAttemptAt])
  @@index([tenantId, documentId, jobType])
}

enum CompanyModuleKey {
  CLINICAL
  PHARMACY
  DRUGSTORE
  BILLING
  CASHBOX
  MANAGEMENT
  LABORATORY
  IMAGING
}

enum CompanyCollaborationResource {
  PRESCRIPTION_REFERRAL
  DISPENSING
  STOCK_VISIBILITY
  RESERVATION
  PURCHASE_TRANSFER
  REPORTING
}

enum CompanyCollaborationDirection {
  ONE_WAY
  TWO_WAY
}

enum CompanyCollaborationStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

enum PrescriptionReferralStatus {
  PENDING
  VIEWED
  ACCEPTED
  PARTIALLY_DISPENSED
  COMPLETED
  REJECTED
  CANCELLED
  EXPIRED
}

model CompanyModuleInstallation {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  companyId      String           @db.Uuid
  businessUnitId String           @db.Uuid
  warehouseId    String?          @db.Uuid
  moduleKey      CompanyModuleKey
  displayName    String?          @db.VarChar(180)
  active         Boolean          @default(true)
  settings       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  businessUnit BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Restrict)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@unique([businessUnitId, moduleKey])
  @@index([tenantId, companyId, moduleKey, active])
  @@index([tenantId, businessUnitId, active])
}

model CompanyCollaborationAgreement {
  id                       String                        @id @default(uuid()) @db.Uuid
  tenantId                 String                        @db.Uuid
  ownerCompanyId           String                        @db.Uuid
  partnerCompanyId         String                        @db.Uuid
  sourceBusinessUnitId     String?                       @db.Uuid
  targetBusinessUnitId     String?                       @db.Uuid
  resource                 CompanyCollaborationResource
  direction                CompanyCollaborationDirection @default(ONE_WAY)
  status                   CompanyCollaborationStatus    @default(DRAFT)
  requiresPatientConsent   Boolean                       @default(true)
  shareMinimumClinicalData Boolean                       @default(true)
  startAt                  DateTime?
  endAt                    DateTime?
  notes                    String?                       @db.Text
  metadata                 Json?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerCompany       Company       @relation("CollaborationOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: Restrict)
  partnerCompany     Company       @relation("CollaborationPartnerCompany", fields: [partnerCompanyId], references: [id], onDelete: Restrict)
  sourceBusinessUnit BusinessUnit? @relation("CollaborationSourceBusinessUnit", fields: [sourceBusinessUnitId], references: [id], onDelete: SetNull)
  targetBusinessUnit BusinessUnit? @relation("CollaborationTargetBusinessUnit", fields: [targetBusinessUnitId], references: [id], onDelete: SetNull)

  @@unique([ownerCompanyId, partnerCompanyId, sourceBusinessUnitId, targetBusinessUnitId, resource])
  @@index([tenantId, ownerCompanyId, status])
  @@index([tenantId, partnerCompanyId, status])
  @@index([tenantId, resource, status])
}

model PrescriptionReferral {
  id                     String                     @id @default(uuid()) @db.Uuid
  tenantId               String                     @db.Uuid
  prescriptionId         String                     @db.Uuid
  sourceCompanyId        String                     @db.Uuid
  sourceBusinessUnitId   String?                    @db.Uuid
  targetCompanyId        String                     @db.Uuid
  targetBusinessUnitId   String?                    @db.Uuid
  status                 PrescriptionReferralStatus @default(PENDING)
  requiresPatientConsent Boolean                    @default(true)
  patientConsentGranted  Boolean                    @default(false)
  patientConsentAt       DateTime?
  patientConsentBy       String?                    @db.VarChar(180)
  sharedPayload          Json?
  rejectionReason        String?                    @db.Text
  expiresAt              DateTime?
  createdById            String?                    @db.Uuid
  updatedById            String?                    @db.Uuid
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prescription       Prescription  @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  sourceCompany      Company       @relation("PrescriptionReferralSourceCompany", fields: [sourceCompanyId], references: [id], onDelete: Restrict)
  sourceBusinessUnit BusinessUnit? @relation("PrescriptionReferralSourceBusinessUnit", fields: [sourceBusinessUnitId], references: [id], onDelete: SetNull)
  targetCompany      Company       @relation("PrescriptionReferralTargetCompany", fields: [targetCompanyId], references: [id], onDelete: Restrict)
  targetBusinessUnit BusinessUnit? @relation("PrescriptionReferralTargetBusinessUnit", fields: [targetBusinessUnitId], references: [id], onDelete: SetNull)
  createdBy          User?         @relation("PrescriptionReferralCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?         @relation("PrescriptionReferralUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([tenantId, targetCompanyId, status, createdAt])
  @@index([tenantId, sourceCompanyId, status, createdAt])
  @@index([tenantId, prescriptionId])
}

model PharmacyFefoRule {
