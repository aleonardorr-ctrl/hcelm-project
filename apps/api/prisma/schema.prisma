model PlatformAdministrativeActionAudit {
  id                        String                                @id @default(uuid()) @db.Uuid
  entityType                PlatformAdministrativeEntityType
  action                    PlatformAdministrativeAction
  targetEntityId            String?                               @db.Uuid
  targetTenantId            String?                               @db.Uuid
  targetCompanyId           String?                               @db.Uuid
  targetUserId              String?                               @db.Uuid
  targetName                String                                @db.VarChar(200)
  targetIdentifier          String?                               @db.VarChar(120)
